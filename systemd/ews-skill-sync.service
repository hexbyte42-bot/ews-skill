[Unit]
Description=EWS Skill Stdio JSON-RPC Daemon
After=network-online.target
Wants=network-online.target

[Service]
User=__RUN_USER__
Group=__RUN_GROUP__
Type=simple
WorkingDirectory=__SKILL_PATH__
EnvironmentFile=__SKILL_PATH__/.env
RuntimeDirectory=ews-skill
RuntimeDirectoryMode=0755
ExecStart=__SKILL_PATH__/bin/ews_skilld --transport unix --socket __SOCKET_PATH__
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
